+/*
+ * Clause 22 (1G) MDIO write.
+ * Register protocol matches fman_memac_mii_acc.c:write_phy_reg_1g().
+ */
+static int
+memac_mdio_writereg(device_t dev, int phy, int reg, int value)
+{
+	struct memac_mdio_softc *sc;
+	uint32_t cfg, ctl;
+
+	sc = device_get_softc(dev);
