 EARLY_DRIVER_MODULE(fman, simplebus, fman_driver, 0, 0,
-    BUS_PASS_BUS + BUS_PASS_ORDER_MIDDLE);
+    BUS_PASS_INTERRUPT + BUS_PASS_ORDER_LAST);
 
 
 static int
@@ -87,18 +91,29 @@ fman_get_clock(struct fman_softc *sc)
 	device_t dev;
 	phandle_t node;
 	pcell_t fman_clock;
+	clk_t clk;
+	uint64_t freq;
 
