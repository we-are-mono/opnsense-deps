+		return (EINVAL);
+
+	/* Copyin the parser microcode from userspace */
+	code_buf = malloc(param->size, M_FMCD, M_WAITOK);
+	if (copyin(param->p_code, code_buf, param->size) != 0) {
+		free(code_buf, M_FMCD);
