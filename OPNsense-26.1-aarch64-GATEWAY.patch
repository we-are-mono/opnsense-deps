+	/* Redirect pointer to kernel buffer */
+	param->p_code = code_buf;
+
+	err = FM_PCD_PrsLoadSw(sc->pcd_handle, (t_FmPcdPrsSwParams *)param);
+	free(code_buf, M_FMCD);
+
+	return (err == E_OK ? 0 : EIO);
+}
