+ * ---------------------------------------------------------------- */
+typedef struct en_exthash_global_mem_s {
+	en_dscp_vlanpcp_map_cfg		dscp_vlanpcp_map;	/* +0, 8B  */
+	en_SEC_failure_stats		SEC_failure_stats;	/* +8, 92B */
+} __attribute__((packed)) en_exthash_global_mem;
