+	-I$S/contrib/ncsw/Peripherals/FM/Rtc \
+	-I$S/contrib/ncsw/Peripherals/QM \
+	-I$S/contrib/ncsw/inc/flib \
+	-I$S/contrib/ncsw/inc/integrations"
+
+makeoptions FMCD_COMPILE_CMD="${DPAA_COMPILE_CMD} \
+	-I$S/../../ASK/freebsd/fmlib/include/fmd \
+	-I$S/../../ASK/freebsd/fmlib/include/fmd/Peripherals \
+	-I$S/../../ASK/freebsd/fmlib/include/fmd/integrations"
