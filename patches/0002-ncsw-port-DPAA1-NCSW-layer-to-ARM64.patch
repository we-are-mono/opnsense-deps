+#define	LIST_FOR_EACH_SAFE	NCSW_LIST_FOR_EACH_SAFE
+#define	LIST_FOR_EACH_OBJECT	NCSW_LIST_FOR_EACH_OBJECT
+#define	LIST_FOR_EACH_OBJECT_SAFE	NCSW_LIST_FOR_EACH_OBJECT_SAFE
+
