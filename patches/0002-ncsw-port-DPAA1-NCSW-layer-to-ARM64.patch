+void
+ARM64_InstructionSync(void)
+{
+
+	__asm __volatile("isb" ::: "memory");
+}
diff --git a/sys/contrib/ncsw/user/env/xx_arm64.c b/sys/contrib/ncsw/user/env/xx_arm64.c
new file mode 100644
index 00000000000..b3afd8b579e
--- /dev/null
+++ b/sys/contrib/ncsw/user/env/xx_arm64.c
@@ -0,0 +1,794 @@
+/*-
