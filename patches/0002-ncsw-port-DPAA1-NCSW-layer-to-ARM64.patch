+#include "core_ext.h"
+
+uint32_t
+ARM64_GetId(void)
+{
+
+	return (PCPU_GET(cpuid));
+}
+
+int
+ARM64_TestAndSet(volatile int *p)
+{
+
+	return (!atomic_cmpset_int((volatile u_int *)p, 0, 1));
+}
