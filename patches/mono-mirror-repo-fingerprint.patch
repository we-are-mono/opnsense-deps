 @sample /usr/local/etc/config.xml.sample
 @shadow /usr/local/etc/pkg/repos/FreeBSD.conf.sample
+@shadow /usr/local/etc/pkg/repos/MonoGateway.conf.sample
 @shadow /usr/local/etc/pkg/repos/OPNsense-aux.conf.sample
 @shadow /usr/local/etc/pkg/repos/OPNsense.conf.sample
diff --git a/src/etc/pkg/fingerprints/OPNsense/trusted/opnsense.mono.si.20260305 b/src/etc/pkg/fingerprints/OPNsense/trusted/opnsense.mono.si.20260305
new file mode 100644
index 00000000000..af6301792bd
--- /dev/null
+++ b/src/etc/pkg/fingerprints/OPNsense/trusted/opnsense.mono.si.20260305
@@ -0,0 +1,2 @@
+function: "sha256"
+fingerprint: "ed8c6cdf38383853b0d6f4c6bf70efa1793d76a57e78317a53653404bcabd931"
diff --git a/src/etc/pkg/repos/MonoGateway.conf.shadow.in b/src/etc/pkg/repos/MonoGateway.conf.shadow.in
new file mode 100644
index 00000000000..4947e72a217
--- /dev/null
+++ b/src/etc/pkg/repos/MonoGateway.conf.shadow.in
@@ -0,0 +1,7 @@
+MonoGateway: {
+  fingerprints: "/usr/local/etc/pkg/fingerprints/OPNsense",
+  url: "%%CORE_PACKAGESITE%%/${ABI}/%%CORE_ABI%%/mono",
+  signature_type: "fingerprints",
+  priority: 11,
+  enabled: yes
+}
