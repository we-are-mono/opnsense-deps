---
 Mk/version.mk                                 |  2 +-
 plist                                         |  2 +
 .../trusted/opnsense.mono.si.20260305         |  2 +
 src/etc/pkg/repos/MonoGateway.conf.shadow.in  |  7 ++
 .../OPNsense/Core/repositories/opnsense.xml   | 86 +------------------
 5 files changed, 15 insertions(+), 84 deletions(-)
 create mode 100644 src/etc/pkg/fingerprints/OPNsense/trusted/opnsense.mono.si.20260305
 create mode 100644 src/etc/pkg/repos/MonoGateway.conf.shadow.in

diff --git a/Mk/version.mk b/Mk/version.mk
index 85c078b1aac..dba5004963f 100644
--- a/Mk/version.mk
+++ b/Mk/version.mk
@@ -36,7 +36,7 @@ CORE_CONFLICTS?=firewall wireguard wireguard-go
